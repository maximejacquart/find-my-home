# Copie en .env et remplis. Jamais commité (.gitignore).

# Envoi du rapport — compte Gmail émetteur + mot de passe d'application
# (https://myaccount.google.com/apppasswords, nécessite validation 2 étapes)
GMAIL_USER=tonadresse@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optionnel — active la source leboncoin (https://firecrawl.dev)
# FIRECRAWL_API_KEY=fc-...

# Optionnel — scoring via API Anthropic. Sinon fallback automatique sur le CLI `claude`.
# ANTHROPIC_API_KEY=sk-ant-...
